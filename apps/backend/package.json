{
  "name": "@wbf-platform/backend",
  "version": "1.0.0",
  "description": "WBF Platform Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "local": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed:opportunities:print": "echo 'Script removed - was for Firebase'",
    "seed:opportunities": "echo 'Script removed - was for Firebase'",
    "export:orgs": "echo 'Script removed - was for Firebase'",
    "seed:orgs+opps": "echo 'Script removed - was for Firebase'",
    "import:orgs+seed": "echo 'Script removed - was for Firebase'",
    "migrate:orgs:embed-opps": "echo 'Script removed - was for Firebase'",
    "create:super-admin": "tsx scripts/create-super-admin.ts",
    "check:super-admin": "tsx scripts/check-super-admin.ts",
    "update:password": "tsx scripts/update-password.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.952.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.0.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.6.2",
    "typescript": "5.8.2"
  }
