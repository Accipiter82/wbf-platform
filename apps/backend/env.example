API_BASE_URL=http://localhost:3101

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=wbf-platform

# Firebase Configuration
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_ADMIN_EMAIL=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# JWT Configuration
JWT_SECRET=

# SMTP Configuration (for sending feedback emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

# Server Configuration
PORT=3101
NODE_ENV=development

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# AWS S3 Configuration
AWS_REGION=eu-north-1
AWS_S3_BUCKET=partnership-project-mainstorage
# Optional custom domain (CloudFront, etc.)
# AWS_S3_PUBLIC_URL=https://partnership-project-mainstorage.s3.eu-north-1.amazonaws.com
# Provide credentials via environment (never commit real keys)
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key