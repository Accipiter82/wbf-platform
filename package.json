{
  "name": "wbf-platform",
  "version": "1.0.0",
  "description": "WBF Organisation Platform - A web-based system for organizations across the Western Balkans",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "local": "turbo run local",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.2",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "axios": "^1.10.0",
    "csv-parser": "^3.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "mime-types": "^3.0.1"
  }
}
